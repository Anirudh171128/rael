# Rael's avatar images. Defaults to the bundled portrait, so nothing is required.
#
# VITE_RAEL_AVATAR_IMG  — circular head shot (header badge + voice call). Default /rael.png
# VITE_RAEL_AVATAR_FULL — full-body portrait (Rael's Desk on the home view). Default /rael-full.png
#
# Both are processed from Rael's character art into transparent PNGs under public/.
# Point these at your own URLs/paths to swap his look.
VITE_RAEL_AVATAR_IMG=
VITE_RAEL_AVATAR_FULL=
