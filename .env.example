# ─── Core ───────────────────────────────────────────────────────────────
# Railway: reference the Postgres plugin, e.g. ${{Postgres.DATABASE_URL}}
# (postgres:// URLs are normalized to asyncpg automatically)
DATABASE_URL=postgresql+asyncpg://rael:rael@localhost:5432/rael
REDIS_URL=redis://localhost:6379/0
APP_ENV=production
# Comma-separated origins allowed to hit the API / WebSocket.
# In single-service production (FastAPI serves the SPA) this can stay empty.
CORS_ORIGINS=

# ─── LLM (provider preference: Gemini → Claude → mock) ──────────────────
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
#ANTHROPIC_API_KEY=
#CLAUDE_MODEL=claude-sonnet-5

# ─── Discovery search executor (Tavily = live web results) ──────────────
TAVILY_API_KEY=

# ─── Outreach email delivery (waterfall: Resend → SendGrid → SMTP) ──────
SENDGRID_API_KEY=
RESEND_API_KEY=

# ─── SMTP — used for login OTPs AND as the outreach email fallback ──────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# ─── Decision gate ──────────────────────────────────────────────────────
APPROVAL_MODE=true
QUALIFY_THRESHOLD=65

# ─── Contact enrichment — Apollo ONLY (no mock contacts, ever) ──────────
# Every enrichment is human-approved from the dashboard; credits are never
# spent autonomously. Without this key, leads wait unenriched.
APOLLO_API_KEY=

# ─── Signal feeds (no data if absent — never mocked) ────────────────────
CRUNCHBASE_API_KEY=
NEWSAPI_KEY=

# ─── WhatsApp notifications (optional) ──────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_REP_NUMBER=
